{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/adamcaviness/agentic-atlas/rubric/v1/axis.schema.json",
  "title": "Agentic Atlas Axis",
  "type": "object",
  "required": ["id", "title", "poles", "indicators"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "poles": {
      "type": "object",
      "required": ["negative", "positive"],
      "additionalProperties": false,
      "properties": {
        "negative": { "type": "string" },
        "positive": { "type": "string" }
      }
    },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/indicator" }
    }
  },
  "$defs": {
    "indicator": {
      "type": "object",
      "required": ["id", "question", "kind", "weight"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
        "question": { "type": "string" },
        "weight": { "type": "number", "exclusiveMinimum": 0 },
        "kind": { "enum": ["measured", "classified"] },
        "answers": {
          "type": "object",
          "minProperties": 2,
          "additionalProperties": { "type": "number", "minimum": -1, "maximum": 1 },
          "description": "Required for classified indicators. Answer key to value in [-1, 1]."
        },
        "signal": { "$ref": "#/$defs/signal" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "classified" } } },
          "then": { "required": ["answers"] }
        },
        {
          "if": { "properties": { "kind": { "const": "measured" } } },
          "then": { "required": ["signal"] }
        }
      ]
    },
    "bands": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered ascending by max_count. A metric resolves to the value of the first band whose max_count is null (catch-all) or >= the metric.",
      "items": {
        "type": "object",
        "required": ["value"],
        "additionalProperties": false,
        "properties": {
          "max_count": { "type": ["integer", "null"], "minimum": 0 },
          "value": { "type": "number", "minimum": -1, "maximum": 1 }
        }
      }
    },
    "signal": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "terms", "bands"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "vocabulary" },
            "terms": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" },
              "description": "Case-insensitive terms matched as whole tokens, not substrings, so a short term like 'ci' does not match inside 'decision'. List inflected forms explicitly (for example 'deploy' and 'deployment')."
            },
            "bands": { "$ref": "#/$defs/bands" }
          }
        },
        {
          "type": "object",
          "required": ["type", "globs", "present", "absent"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "path_presence" },
            "globs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "present": { "type": "number", "minimum": -1, "maximum": 1 },
            "absent": { "type": "number", "minimum": -1, "maximum": 1 }
          }
        },
        {
          "type": "object",
          "required": ["type", "globs", "bands"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "path_count" },
            "globs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "bands": { "$ref": "#/$defs/bands" }
          }
        },
        {
          "type": "object",
          "required": ["type", "metric", "bands"],
          "additionalProperties": false,
          "description": "A deterministic fact read from the target's git history, banded to a value.",
          "properties": {
            "type": { "const": "git_stats" },
            "metric": { "enum": ["commit_count", "contributor_count", "age_days", "tag_count"] },
            "bands": { "$ref": "#/$defs/bands" }
          }
        },
        {
          "type": "object",
          "required": ["type", "metric", "bands"],
          "additionalProperties": false,
          "description": "A point-in-time fact read from the GitHub host API for the target's origin remote, banded to a value. Unresolved (and counted against coverage) when there is no origin remote, no network, or the API call fails.",
          "properties": {
            "type": { "const": "github_api" },
            "metric": { "enum": ["stars", "forks", "watchers", "open_issues"] },
            "bands": { "$ref": "#/$defs/bands" }
          }
        }
      ]
    }
  }
}
