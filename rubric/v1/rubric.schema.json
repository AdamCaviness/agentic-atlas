{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/adamcaviness/agentic-workflow-atlas/rubric/v1/rubric.schema.json",
  "title": "Agentic Workflow Atlas Rubric Manifest",
  "type": "object",
  "required": ["rubric_version", "title", "axes"],
  "additionalProperties": false,
  "properties": {
    "rubric_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of the rubric. See docs/versioning.md."
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$",
        "description": "Axis id, matching a directory under axes/."
      },
      "uniqueItems": true
    }
  }
}
