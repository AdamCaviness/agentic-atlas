{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/adamavo/agentic-workflow-atlas/rubric/schema.json",
  "title": "Agentic Workflow Atlas Rubric",
  "type": "object",
  "required": ["rubric_version", "title", "axes"],
  "additionalProperties": false,
  "properties": {
    "rubric_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of the rubric. See docs/versioning.md."
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "axes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/axis" }
    }
  },
  "$defs": {
    "axis": {
      "type": "object",
      "required": ["id", "title", "poles", "indicators"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "scale": { "type": "number", "exclusiveMinimum": 0, "default": 10 },
        "poles": {
          "type": "object",
          "required": ["negative", "positive"],
          "additionalProperties": false,
          "properties": {
            "negative": { "type": "string" },
            "positive": { "type": "string" }
          }
        },
        "indicators": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/indicator" }
        }
      }
    },
    "indicator": {
      "type": "object",
      "required": ["id", "question", "kind", "weight"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "question": { "type": "string" },
        "weight": { "type": "number", "exclusiveMinimum": 0 },
        "kind": { "enum": ["measured", "classified"] },
        "answers": {
          "type": "object",
          "minProperties": 2,
          "additionalProperties": { "type": "number", "minimum": -1, "maximum": 1 },
          "description": "Required for classified indicators. Answer key to value in [-1, 1]."
        },
        "signal": { "$ref": "#/$defs/signal" }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "classified" } } },
          "then": { "required": ["answers"] }
        },
        {
          "if": { "properties": { "kind": { "const": "measured" } } },
          "then": { "required": ["signal"] }
        }
      ]
    },
    "signal": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "terms", "bands"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "vocabulary" },
            "terms": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "bands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["value"],
                "additionalProperties": false,
                "properties": {
                  "max_count": { "type": ["integer", "null"], "minimum": 0 },
                  "value": { "type": "number", "minimum": -1, "maximum": 1 }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "globs", "present", "absent"],
          "additionalProperties": false,
          "properties": {
            "type": { "const": "path_presence" },
            "globs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "present": { "type": "number", "minimum": -1, "maximum": 1 },
            "absent": { "type": "number", "minimum": -1, "maximum": 1 }
          }
        }
      ]
    }
  }
}
